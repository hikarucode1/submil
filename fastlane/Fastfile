default_platform(:ios)

APP_IDENTIFIER = "com.hikaru.failuremuseum.submil".freeze
SCHEME = "submil".freeze
XCODEPROJ = "submil.xcodeproj".freeze

platform :ios do
  before_all do
    # CI では一時キーチェーンを用意する (match の証明書インストール先)。
    setup_ci if is_ci
  end

  # App Store Connect API Key を読み込む (2FA 不要・CI 向け)。
  # 秘密鍵 (.p8) は base64 化して ASC_KEY_CONTENT に入れる。
  private_lane :asc_api_key do
    app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_CONTENT"),
      is_key_content_base64: true,
      in_house: false
    )
  end

  desc "証明書・プロビジョニングプロファイルを match で同期する"
  lane :certificates do
    key = asc_api_key
    # CI では readonly (生成せず取得のみ)。
    match(type: "appstore", app_identifier: APP_IDENTIFIER, api_key: key, readonly: is_ci)
  end

  desc "ビルドして TestFlight にアップロードする (fastlane beta)"
  lane :beta do
    key = asc_api_key
    match(type: "appstore", app_identifier: APP_IDENTIFIER, api_key: key, readonly: is_ci)

    # 直近の TestFlight ビルド番号 +1。まだ無ければ 1 から。
    # 注意: version 未指定のため「現行マーケティングバージョンの最新ビルド」を基準にする。
    # MARKETING_VERSION を上げた直後は番号が 1 に戻り得るので、必要なら version: を明示する。
    build_number = latest_testflight_build_number(
      api_key: key,
      app_identifier: APP_IDENTIFIER,
      initial_build_number: 0
    ).to_i + 1

    # Info.plist 自動生成プロジェクトのため、CURRENT_PROJECT_VERSION を
    # ビルド時に上書きして CFBundleVersion を更新する (pbxproj は変更しない)。
    build_app(
      scheme: SCHEME,
      project: XCODEPROJ,
      export_method: "app-store",
      xcargs: "CURRENT_PROJECT_VERSION=#{build_number}",
      export_options: {
        provisioningProfiles: {
          APP_IDENTIFIER => "match AppStore #{APP_IDENTIFIER}"
        }
      }
    )

    upload_to_testflight(
      api_key: key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end

  desc "App Store 用スクリーンショット (#50) を撮影する (Snapfile 参照)"
  lane :screenshots do
    # ローカル撮影のみ。証明書も ASC API Key も不要。
    capture_screenshots
    UI.success("スクショを ./fastlane/screenshots 以下に出力しました。")
    UI.message("訴求文言つきの枠を付ける場合は `bundle exec fastlane frame_screenshots` を実行してください。")
  end

  desc "撮影済みスクショに端末フレーム + 訴求文言を付ける (#50 文言付き訴求デザイン)"
  lane :frame_screenshots do
    # frameit は初回に端末フレーム画像 (Facebook Design Frames) を取得する。
    # 文言は fastlane/screenshots/<lang>/title.strings、詳細レイアウトは Framefile.json で制御。
    frameit(path: "./fastlane/screenshots")
  end

  desc "スクショ (#50) を含めてストアへ反映する"
  lane :upload_screenshots do
    key = asc_api_key
    deliver(
      api_key: key,
      app_identifier: APP_IDENTIFIER,
      screenshots_path: "./fastlane/screenshots",
      skip_binary_upload: true,
      skip_metadata: true,      # メタデータは upload_metadata 側で扱う
      skip_screenshots: false,
      overwrite_screenshots: true,
      force: true,
      submit_for_review: false,
      run_precheck_before_submit: false
    )
  end

  desc "ストアメタデータ (#51) を App Store Connect に反映する (バイナリは送らない)"
  lane :upload_metadata do
    key = asc_api_key
    deliver(
      api_key: key,
      app_identifier: APP_IDENTIFIER,
      metadata_path: "./fastlane/metadata",
      skip_binary_upload: true,
      # スクリーンショット (#50) 準備後に false へ変更する。
      skip_screenshots: true,
      force: true,            # HTML プレビューの確認をスキップ (CI 向け)
      submit_for_review: false,
      run_precheck_before_submit: false
    )
  end
end
