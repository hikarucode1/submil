# fastlane の環境変数サンプル (#55)。
# ローカルでは `.env` にコピーして値を設定する (.env は .gitignore 済み)。
# CI では GitHub Actions の Secrets に同名で登録する。

# --- App Store Connect API Key ---
# App Store Connect > Users and Access > Integrations > App Store Connect API で発行。
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# 発行した .p8 を base64 で1行にしたもの:  base64 -i AuthKey_XXXX.p8 | tr -d '\n'
ASC_KEY_CONTENT=BASE64_ENCODED_P8_CONTENTS

# --- match (証明書管理) ---
# 証明書を保管する private git リポジトリ (実在の所在は Secret 側に置く)。
MATCH_GIT_URL=https://github.com/<org>/<certs-repo>.git
# match の暗号化パスフレーズ。
MATCH_PASSWORD=your-match-passphrase
# CI で証明書 private リポを clone する場合のみ: base64("<user>:<PAT>")
# MATCH_GIT_BASIC_AUTHORIZATION=BASE64_USER_COLON_PAT
